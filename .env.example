# Public site URL for canonical, sitemap, Open Graph
PUBLIC_SITE_URL=http://localhost:4321

# Supabase project
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# Comma-separated admin emails allowed to access /admin
ADMIN_EMAILS=

# Optional: used only for server-only maintenance scripts if you add them later
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare R2 media storage
# In production, NK_MEDIA is provided by the R2 binding in wrangler.jsonc.
# For public images, set a custom domain or public bucket URL here.
CLOUDFLARE_R2_PUBLIC_URL=

# Optional site-wide scripts
# GSC verification meta content only, not full tag.
PUBLIC_GOOGLE_SITE_VERIFICATION=
# Google Analytics measurement ID, e.g. G-XXXXXXXXXX.
PUBLIC_GA_ID=
# Google Tag Manager container ID, e.g. GTM-XXXXXXX.
PUBLIC_GTM_ID=
