---
const { items = [] } = Astro.props as { items: { question: string; answer: string }[] };
---
{items.length > 0 && (
  <section class="space-y-3">
    <h2 class="text-2xl font-semibold">Pertanyaan umum</h2>
    {items.map((item) => (
      <details class="rounded-2xl border border-line bg-surface p-4">
        <summary class="cursor-pointer font-semibold">{item.question}</summary>
        <p class="mt-3 text-sm leading-7 text-muted">{item.answer}</p>
      </details>
    ))}
  </section>
)}
