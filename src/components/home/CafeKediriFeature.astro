---
import type { Place } from '@/types/place';
import type { SeoPage } from '@/types/seo-page';

const { page, places = [] } = Astro.props as { page?: SeoPage | null; places?: Place[] };
const title = page?.h1 || 'Cafe Kediri';
const description = page?.description || 'Kurasi cafe Kediri untuk ngopi, WFC, nugas, ngobrol, date santai, sampai cari suasana baru di area kota dan sekitarnya.';
const targetHref = `/${page?.slug || 'tempat-ngopi-kediri'}/`;
const heroPlace = places.find((place) => place.featured_image_url) || places[0];
const previewPlaces = places.slice(0, 3);
const moodPills = [
  { label: 'Cafe', href: '/cafe-kediri/' },
  { label: 'Coffee shop' },
  { label: 'WFC', href: '/wfc-kediri/' },
  { label: 'Tempat ngopi', href: '/tempat-ngopi-kediri/' },
  { label: 'View alam', href: '/cafe-view-alam-kediri/' },
  { label: 'Murah', href: '/cafe-murah-kediri/' }
];
---
<section class="border-y border-ink bg-paper py-10">
  <div class="mx-auto max-w-[1180px] px-4 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[1fr_420px] lg:items-stretch">
      <div class="section-masthead border border-ink p-5 sm:p-6">
        <div class="flex flex-wrap items-start justify-between gap-4 border-b border-ink pb-5">
          <div>
            <p class="editorial-label">Index cafe lokal</p>
            <h2 class="display-heading mt-3 text-6xl sm:text-8xl">{title}</h2>
          </div>
          <a href={targetHref} class="rounded-full border border-ink bg-ink px-5 py-3 font-mono text-xs font-bold uppercase tracking-[0.14em] text-paper no-underline">Buka index</a>
        </div>

        <div class="mt-5 grid gap-5 lg:grid-cols-[.85fr_1fr]">
          <div class="border border-ink bg-surface p-4">
            <p class="font-mono text-xs uppercase tracking-[0.18em] text-muted">Catatan editorial</p>
            <p class="mt-3 text-base font-extrabold leading-7 text-ink">Cafe Kediri bukan cuma tempat beli kopi. Ini shortlist buat memilih tempat berdasarkan kebutuhan datang.</p>
            <p class="mt-3 text-sm leading-7 text-muted">{description}</p>
          </div>

          <div class="grid content-between gap-4">
            <div class="flex flex-wrap gap-2">
              {moodPills.map((pill) => pill.href ? <a href={pill.href} class="rounded-full border border-ink bg-surface px-3 py-1.5 font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-ink no-underline hover:bg-butter">{pill.label}</a> : <span class="rounded-full border border-ink bg-surface px-3 py-1.5 font-mono text-[11px] font-bold uppercase tracking-[0.12em] text-ink">{pill.label}</span>)}
            </div>
            <div class="grid grid-cols-3 border border-ink bg-surface text-center font-mono text-xs uppercase tracking-[0.12em]">
              <div class="border-r border-ink p-3"><p class="text-2xl font-black tracking-[-0.05em]">{places.length}</p><p class="mt-1 text-muted">listing</p></div>
              <div class="border-r border-ink p-3"><p class="text-2xl font-black tracking-[-0.05em]">3</p><p class="mt-1 text-muted">mood</p></div>
              <div class="p-3"><p class="text-2xl font-black tracking-[-0.05em]">1</p><p class="mt-1 text-muted">index</p></div>
            </div>
          </div>
        </div>

        <div class="mt-5 grid gap-3 sm:grid-cols-3">
          {previewPlaces.length ? previewPlaces.map((place, index) => (
            <a href={`/tempat/${place.slug}/`} class="group border border-ink bg-surface p-4 no-underline transition hover:-translate-y-1 hover:shadow-offset">
              <p class="font-mono text-xs uppercase tracking-[0.18em] text-muted">0{index + 1}</p>
              <h3 class="mt-3 font-display text-2xl font-black uppercase leading-none tracking-[-0.06em]">{place.name}</h3>
              <p class="mt-3 line-clamp-2 text-xs leading-5 text-muted">{place.excerpt || place.area_name || 'Cafe Kediri pilihan editorial.'}</p>
            </a>
          )) : (
            <div class="border border-ink bg-surface p-4 sm:col-span-3">
              <p class="font-mono text-xs uppercase tracking-[0.18em] text-muted">Belum ada listing</p>
              <p class="mt-2 text-sm leading-6 text-muted">Publish tempat dari admin dengan kategori cafe/coffee shop untuk mengisi section ini.</p>
            </div>
          )}
        </div>
      </div>

      <a href={heroPlace ? `/tempat/${heroPlace.slug}/` : targetHref} class="group grid overflow-hidden border border-ink bg-surface no-underline shadow-offset">
        <div class="relative min-h-80 overflow-hidden border-b border-ink">
          {heroPlace?.featured_image_url ? (
            <img src={heroPlace.featured_image_url} alt={heroPlace.featured_image_alt || heroPlace.name} class="h-full min-h-80 w-full object-cover transition duration-300 group-hover:scale-[1.03]" loading="lazy" />
          ) : (
            <div class="flex h-full min-h-80 items-center justify-center bg-[linear-gradient(135deg,rgb(var(--color-sky)/.45),rgb(var(--color-butter)/.28))]">
              <div class="grid h-40 w-40 place-items-center rounded-full border border-ink bg-surface font-mono text-xs uppercase tracking-[0.18em] text-muted">Cafe Kediri</div>
            </div>
          )}
          <span class="absolute left-4 top-4 rounded-full border border-ink bg-surface px-3 py-1.5 font-mono text-[10px] font-black uppercase tracking-[0.16em] text-ink">visual pick</span>
        </div>
        <div class="p-5">
          <p class="font-mono text-xs uppercase tracking-[0.18em] text-muted">Featured from index</p>
          <h3 class="display-heading mt-2 text-4xl">{heroPlace?.name || 'Cafe Kediri pilihan'}</h3>
          <p class="mt-3 text-sm leading-6 text-muted">{heroPlace?.excerpt || 'Gambar akan otomatis memakai foto dari tempat yang masuk filter cafe Kediri.'}</p>
        </div>
      </a>
    </div>
  </div>
</section>
