---
import { QUICK_KEYWORDS } from '@/lib/constants';
---
<section class="border-b border-ink bg-ink text-paper">
  <div class="nk-scrollbar mx-auto flex max-w-[1180px] justify-start gap-4 overflow-x-auto px-4 py-4 font-mono text-xs font-bold uppercase tracking-[0.16em] sm:flex-wrap sm:justify-center sm:px-6 lg:px-8">
    {QUICK_KEYWORDS.map((item) => <a href={item.href} class="shrink-0 py-1 text-paper no-underline hover:text-butter">{item.label}</a>)}
  </div>
</section>
