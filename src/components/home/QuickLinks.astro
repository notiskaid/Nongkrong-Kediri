---
import { QUICK_KEYWORDS } from '@/lib/constants';
---
<section>
  <div class="flex items-end justify-between gap-4">
    <h2 class="text-2xl font-semibold">Cari berdasarkan kebutuhan</h2>
  </div>
  <div class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
    {QUICK_KEYWORDS.map((item) => (
      <a href={item.href} class="card-hover rounded-2xl border border-line bg-surface p-4 no-underline">
        <i class={`${item.icon} text-xl`}></i>
        <p class="mt-3 font-semibold">{item.label}</p>
        <p class="mt-1 text-xs text-muted">Lihat listing otomatis</p>
      </a>
    ))}
  </div>
</section>
