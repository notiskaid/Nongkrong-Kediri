---
import PlaceListingGrid from '@/components/listing/PlaceListingGrid.astro';
import type { Place } from '@/types/place';
const { places = [] } = Astro.props as { places: Place[] };
---
<section>
  <div class="mb-4 flex flex-wrap items-end justify-between gap-4">
    <div>
      <p class="text-xs uppercase tracking-[0.25em] text-muted">Kerja dari cafe</p>
      <h2 class="mt-2 text-3xl font-semibold">WFC yang lebih siap buat laptopan</h2>
      <p class="mt-2 max-w-2xl text-sm leading-6 text-muted">Prioritas tempat dengan kebutuhan dasar seperti WiFi, colokan, dan suasana yang lebih masuk akal untuk fokus.</p>
    </div>
    <a href="/wfc-kediri/" class="text-sm no-underline">lihat WFC →</a>
  </div>
  <PlaceListingGrid places={places} />
</section>
