---
import type { TaxonomyTerm } from '@/types/taxonomy';
import { isRedirectPath } from '@/lib/seo/silo';
const { areas = [] } = Astro.props as { areas: TaxonomyTerm[] };
const visibleAreas = areas.filter((area) => !isRedirectPath(`/area/${area.slug}/`));
---
<section class="section-masthead border border-ink p-6">
  <div class="max-w-2xl">
    <p class="text-xs uppercase tracking-[0.25em] text-muted">Peta rasa lokal</p>
    <h2 class="display-heading mt-2 text-5xl sm:text-7xl">Cari dari area</h2>
    <p class="mt-2 text-sm leading-6 text-muted">Mulai dari pusat kota, sekitar kampus, sisi timur, sampai titik transit seperti stasiun.</p>
  </div>
  <div class="mt-5 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
    {visibleAreas.map((area) => <a href={`/area/${area.slug}/`} class="card-hover border border-ink bg-paper p-5 no-underline"><span class="editorial-label">area</span><p class="mt-2 font-display text-2xl font-black uppercase leading-none tracking-[-0.05em]">{area.name}</p>{area.description && <p class="mt-2 line-clamp-2 text-xs leading-5 text-muted">{area.description}</p>}</a>)}
  </div>
</section>
