---
const { icon, href, class: className = '' } = Astro.props;
const base = `inline-flex items-center gap-1.5 rounded-full border border-ink bg-surface px-3 py-1 font-mono text-[10px] font-bold uppercase tracking-[0.14em] text-muted no-underline ${className}`;
---
{href ? (
  <a href={href} class={base}>{icon && <i class={icon}></i>}<slot /></a>
) : (
  <span class={base}>{icon && <i class={icon}></i>}<slot /></span>
)}
