---
const { title = 'Belum ada data', description = 'Data akan muncul setelah tempat dipublish.' } = Astro.props;
---
<div class="rounded-2xl border border-dashed border-line bg-surface p-8 text-center">
  <p class="text-lg font-semibold text-ink">{title}</p>
  <p class="mt-2 text-sm text-muted">{description}</p>
</div>
