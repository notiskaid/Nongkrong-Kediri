---
const { title = 'Belum ada data', description = 'Data akan muncul setelah tempat dipublish.' } = Astro.props;
---
<div class="border border-dashed border-ink bg-surface p-10 text-center shadow-offset">
  <p class="editorial-label">kosong dulu</p>
  <p class="display-heading mt-3 text-4xl text-ink">{title}</p>
  <p class="mx-auto mt-2 max-w-md text-sm leading-6 text-muted">{description}</p>
</div>
