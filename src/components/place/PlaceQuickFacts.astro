---
import type { Place } from '@/types/place';
import { formatPriceRange } from '@/lib/utils/format-price';
import { openingHoursLabel } from '@/lib/utils/opening-hours';
const { place } = Astro.props as { place: Place };
const facts = [
  { icon: 'ri-map-pin-line', label: 'Area', value: place.area_name || 'Kediri' },
  { icon: 'ri-time-line', label: 'Jam buka', value: openingHoursLabel(place.opening_hours) },
  { icon: 'ri-money-dollar-circle-line', label: 'Harga', value: formatPriceRange(place.price_min, place.price_max, place.price_label) },
  { icon: 'ri-star-line', label: 'Rating', value: place.rating ? `${place.rating}${place.rating_count ? ` (${place.rating_count})` : ''}` : 'Belum tersedia' }
];
---
<div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
  {facts.map((fact) => (
    <div class="rounded-2xl border border-line bg-surface p-4">
      <div class="flex items-center gap-2 text-xs text-muted"><i class={fact.icon}></i>{fact.label}</div>
      <p class="mt-2 text-sm font-semibold leading-6">{fact.value}</p>
    </div>
  ))}
</div>
