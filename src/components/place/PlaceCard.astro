---
import Badge from '@/components/base/Badge.astro';
import type { Place } from '@/types/place';
import { formatPriceRange } from '@/lib/utils/format-price';
import { openingHoursLabel } from '@/lib/utils/opening-hours';

const { place, headingLevel = 2 } = Astro.props as { place: Place; headingLevel?: 2 | 3 };
const headingClass = 'text-xl font-bold leading-snug';
const topFacilities = place.facilities?.slice(0, 3) || [];
const topUseCases = place.use_cases?.slice(0, 2) || [];
const primaryCategory = place.categories?.[0]?.name;
---
<article class="card-hover group overflow-hidden rounded-[1.75rem] border border-line bg-surface shadow-soft">
  <div class="relative">
    <a href={`/tempat/${place.slug}/`} class="block no-underline" aria-label={`Lihat ${place.name}`}>
      {place.featured_image_url ? (
        <img src={place.featured_image_url} alt={place.featured_image_alt || place.name} class="h-52 w-full object-cover transition duration-300 group-hover:scale-[1.02]" loading="lazy" />
      ) : (
        <div class="flex h-52 w-full items-center justify-center bg-paper text-sm text-muted">Foto belum tersedia</div>
      )}
    </a>
    <div class="absolute left-3 top-3 flex flex-wrap gap-2">
      {primaryCategory && <span class="rounded-full bg-paper/90 px-3 py-1 text-xs font-semibold backdrop-blur">{primaryCategory}</span>}
      {place.rating && <span class="rounded-full bg-ink px-3 py-1 text-xs font-semibold text-paper"><i class="ri-star-fill"></i> {place.rating}</span>}
    </div>
  </div>
  <div class="p-5">
    <div class="mb-3 flex flex-wrap gap-2">
      {place.area_name && <Badge icon="ri-map-pin-line">{place.area_name}</Badge>}
      {place.price_label && <Badge icon="ri-money-dollar-circle-line">{place.price_label}</Badge>}
    </div>
    {headingLevel === 3 ? <h3 class={headingClass}><a href={`/tempat/${place.slug}/`} class="no-underline hover:text-muted">{place.name}</a></h3> : <h2 class={headingClass}><a href={`/tempat/${place.slug}/`} class="no-underline hover:text-muted">{place.name}</a></h2>}
    {place.excerpt && <p class="mt-2 line-clamp-3 text-sm leading-6 text-muted">{place.excerpt}</p>}
    <div class="mt-4 flex flex-wrap gap-2">
      {topUseCases.map((term) => <Badge icon={term.icon}>{term.name}</Badge>)}
      {topFacilities.map((term) => <Badge icon={term.icon}>{term.name}</Badge>)}
    </div>
    <div class="mt-5 flex flex-wrap items-center gap-x-4 gap-y-2 border-t border-line pt-4 text-xs text-muted">
      <span><i class="ri-money-dollar-circle-line"></i> {formatPriceRange(place.price_min, place.price_max, place.price_label)}</span>
      <span><i class="ri-time-line"></i> {openingHoursLabel(place.opening_hours)}</span>
    </div>
    <a href={`/tempat/${place.slug}/`} class="mt-4 inline-flex items-center gap-1 text-sm font-semibold no-underline">Lihat detail <i class="ri-arrow-right-line"></i></a>
  </div>
</article>
