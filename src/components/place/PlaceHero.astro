---
import Badge from '@/components/base/Badge.astro';
import Button from '@/components/base/Button.astro';
import type { Place } from '@/types/place';
const { place } = Astro.props as { place: Place };
---
<section class="section-masthead grid gap-8 border-y border-ink p-6 lg:grid-cols-[1.05fr_.95fr] lg:items-start">
  <div>
    <div class="mb-4 flex flex-wrap gap-2">
      {place.area_name && <Badge icon="ri-map-pin-line">{place.area_name}</Badge>}
      {place.rating && <Badge icon="ri-star-line">Rating {place.rating}</Badge>}
      {place.price_label && <Badge icon="ri-money-dollar-circle-line">{place.price_label}</Badge>}
    </div>
    <h1 class="display-heading max-w-4xl text-6xl sm:text-8xl">{place.name}</h1>
    {place.excerpt && <p class="mt-5 max-w-2xl text-lg leading-8 text-muted">{place.excerpt}</p>}
    <div class="mt-6 grid gap-3 sm:grid-cols-3">
      <div class="border border-ink bg-surface p-4"><p class="font-mono text-xs uppercase tracking-[0.14em] text-muted">Area</p><p class="mt-1 font-semibold">{place.area_name || 'Kediri'}</p></div>
      <div class="border border-ink bg-surface p-4"><p class="font-mono text-xs uppercase tracking-[0.14em] text-muted">Kisaran harga</p><p class="mt-1 font-semibold">{place.price_label || 'Belum dicatat'}</p></div>
      <div class="border border-ink bg-surface p-4"><p class="font-mono text-xs uppercase tracking-[0.14em] text-muted">Cocok untuk</p><p class="mt-1 line-clamp-1 font-semibold">{place.use_cases?.[0]?.name || 'Nongkrong'}</p></div>
    </div>
    <div class="mt-6 flex flex-wrap gap-3">
      {place.google_maps_url && <Button href={place.google_maps_url} variant="primary" icon="ri-map-2-line">Buka Google Maps</Button>}
      <Button href="#lapor" icon="ri-error-warning-line">Lapor data salah</Button>
    </div>
  </div>
  <div class="border border-ink bg-surface p-2 shadow-offset">
    {place.featured_image_url ? (
      <a href={place.featured_image_url} class="nk-photo-frame" data-lightbox-image aria-label={`Lihat foto ${place.name}`}>
        <img src={place.featured_image_url} alt={place.featured_image_alt || place.name} class="aspect-[4/3]" />
      </a>
    ) : (
      <div class="flex aspect-[4/3] items-center justify-center bg-paper text-muted">Belum ada foto</div>
    )}
  </div>
</section>

<script is:inline>
  document.addEventListener('click', (event) => {
    const trigger = event.target.closest('[data-lightbox-image]');
    if (!trigger) return;
    event.preventDefault();
    let dialog = document.querySelector('.nk-lightbox');
    if (!dialog) {
      dialog = document.createElement('dialog');
      dialog.className = 'nk-lightbox';
      dialog.innerHTML = '<img alt=""><button type="button">Tutup</button>';
      dialog.querySelector('button').addEventListener('click', () => dialog.close());
      dialog.addEventListener('click', (clickEvent) => {
        if (clickEvent.target === dialog) dialog.close();
      });
      document.body.appendChild(dialog);
    }
    const image = dialog.querySelector('img');
    image.src = trigger.href;
    image.alt = trigger.querySelector('img')?.alt || 'Foto tempat';
    dialog.showModal();
  });
</script>
