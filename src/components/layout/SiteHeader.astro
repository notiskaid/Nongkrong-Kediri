---
import { SITE } from '@/lib/constants';
import ThemeToggle from './ThemeToggle';
import { SILO_CLUSTERS } from '@/lib/seo/silo';

const primaryNav = [
  { label: 'Home', href: '/' },
  { label: 'Tempat Ngopi', href: '/tempat-ngopi-kediri/' },
  { label: 'Cafe', href: '/cafe-kediri/' },
  { label: 'WFC', href: '/wfc-kediri/' },
  { label: 'Area', href: '/area/' }
];

const exploreGroups = [
  {
    title: 'Produktivitas',
    links: SILO_CLUSTERS.productivity.pages
  },
  {
    title: 'Suasana',
    links: SILO_CLUSTERS.ambience.pages
  }
];

const editorialLinks = [
  { label: 'Iklan', href: '/iklan/' },
  { label: 'Tentang', href: '/tentang/' },
  { label: 'Kontak', href: '/kontak/' }
];
---
<header class="fixed left-1/2 top-3 z-50 w-[calc(100%-24px)] max-w-6xl -translate-x-1/2 border border-ink bg-surface/92 font-mono text-[11px] uppercase tracking-[0.12em] shadow-offset backdrop-blur-xl">
  <div class="flex items-center justify-between gap-2 px-2 py-2">
    <nav class="flex min-w-0 items-center gap-2" aria-label="Navigasi utama">
      <a href="/" class="group flex items-center gap-2 border border-ink bg-butter px-3 py-2 font-black no-underline" aria-label={SITE.name}>
        <span class="grid size-6 place-items-center border border-ink bg-paper"><i class="ri-cup-line text-sm"></i></span>
        <span class="hidden leading-none md:inline">Nongkrong<br />Kediri</span>
      </a>
      <div class="hidden items-center gap-1 lg:flex">
        {primaryNav.map((item) => <a href={item.href} class="border border-transparent px-3 py-2 font-black text-ink no-underline hover:border-ink hover:bg-paper">{item.label}</a>)}
        <details class="group relative">
          <summary class="list-none border border-transparent px-3 py-2 font-black text-ink hover:border-ink hover:bg-paper [&::-webkit-details-marker]:hidden">Jelajah <i class="ri-arrow-down-s-line"></i></summary>
          <div class="absolute left-0 top-[calc(100%+10px)] grid w-[560px] grid-cols-2 gap-3 border border-ink bg-surface p-4 text-ink shadow-offset">
            {exploreGroups.map((group) => (
              <div>
                <p class="mb-2 border-b border-ink pb-2 text-[10px] font-black tracking-[0.22em] text-muted">{group.title}</p>
                <div class="grid gap-1">
                  {group.links.map((link) => <a href={link.href} class="border border-transparent px-3 py-2 text-xs font-bold no-underline hover:border-ink hover:bg-paper">{link.label}</a>)}
                </div>
              </div>
            ))}
          </div>
        </details>
        {editorialLinks.map((item) => <a href={item.href} class="border border-transparent px-3 py-2 font-black text-ink no-underline hover:border-ink hover:bg-paper">{item.label}</a>)}
      </div>
    </nav>
    <div class="flex items-center gap-2">
      <a href="/search/" class="focus-ring flex size-9 items-center justify-center border border-ink bg-paper no-underline" aria-label="Cari tempat"><i class="ri-search-line"></i></a>
      <ThemeToggle client:load />
      <a href="/kontak/" class="focus-ring hidden border border-ink bg-ink px-4 py-2 font-black text-paper no-underline sm:inline-flex">Kontak</a>
      <button type="button" class="focus-ring flex size-9 items-center justify-center border border-ink bg-butter lg:hidden" data-menu-toggle aria-controls="mobile-menu" aria-expanded="false" aria-label="Buka menu"><i class="ri-menu-3-line"></i></button>
    </div>
  </div>
  <div id="mobile-menu" class="absolute left-0 right-0 top-[calc(100%+8px)] hidden max-h-[calc(100vh-96px)] overflow-y-auto border border-ink bg-surface p-3 shadow-offset lg:hidden" data-mobile-menu>
    <nav class="grid gap-3" aria-label="Navigasi mobile">
      <div class="grid grid-cols-2 gap-2">
        {primaryNav.map((item) => <a href={item.href} class="min-h-11 border border-ink bg-paper px-3 py-2 font-black no-underline">{item.label}</a>)}
      </div>
      {exploreGroups.map((group) => (
        <div class="border border-ink bg-paper p-3">
          <p class="mb-2 text-[10px] font-black tracking-[0.22em] text-muted">{group.title}</p>
          <div class="grid gap-1">
            {group.links.map((link) => <a href={link.href} class="min-h-10 py-2 font-bold no-underline">{link.label}</a>)}
          </div>
        </div>
      ))}
      <div class="grid grid-cols-3 gap-2">
        {editorialLinks.map((item) => <a href={item.href} class="min-h-11 border border-ink bg-ink px-3 py-2 text-center font-bold text-paper no-underline">{item.label}</a>)}
      </div>
    </nav>
  </div>
</header>
<script is:inline>
  document.querySelectorAll('[data-menu-toggle]').forEach((button) => {
    button.addEventListener('click', () => {
      const menu = document.querySelector('[data-mobile-menu]');
      const expanded = button.getAttribute('aria-expanded') === 'true';
      button.setAttribute('aria-expanded', String(!expanded));
      menu?.classList.toggle('hidden', expanded);
    });
  });
</script>
