---
import { SITE } from '@/lib/constants';
import { SILO_AREAS, SILO_CLUSTERS, SILO_PILLARS } from '@/lib/seo/silo';

const footerGroups = [
  {
    title: 'Pilar',
    links: SILO_PILLARS
  },
  {
    title: 'Area',
    links: SILO_AREAS
  },
  {
    title: 'Produktivitas',
    links: SILO_CLUSTERS.productivity.pages
  },
  {
    title: 'Pilihan berdasarkan kebutuhan',
    links: [...SILO_CLUSTERS.ambience.pages, ...SILO_CLUSTERS.access_time.pages].slice(0, 5)
  }
];

const metaLinks = [
  { label: 'Tentang editorial', href: '/tentang/' },
  { label: 'Disclaimer & akurasi data', href: '/disclaimer/' },
  { label: 'Iklan & sponsor', href: '/iklan/' },
  { label: 'Kontak', href: '/kontak/' },
  { label: 'Sitemap', href: '/sitemap.xml' },
  { label: 'RSS', href: '/rss.xml' }
];
---
<footer class="border-t border-ink bg-ink text-paper">
  <div class="mx-auto max-w-[1180px] px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-[1.1fr_1.6fr]">
      <div class="border border-paper bg-paper p-6 text-ink shadow-offset">
        <p class="font-mono text-xs font-black uppercase tracking-[0.22em] text-muted">Direktori Cafe Kediri</p>
        <p class="display-heading mt-3 text-6xl">{SITE.name}</p>
        <p class="mt-4 max-w-xl text-sm leading-7 text-muted">{SITE.description}</p>
        <div class="mt-6 grid grid-cols-3 border border-ink text-center font-mono text-[10px] font-black uppercase tracking-[0.14em]">
          <a href="/tempat-ngopi-kediri/" class="border-r border-ink p-3 no-underline">Ngopi</a>
          <a href="/wfc-kediri/" class="border-r border-ink p-3 no-underline">WFC</a>
          <a href="/kontak/" class="p-3 no-underline">Kontak</a>
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        {footerGroups.map((group) => (
          <nav class="border border-paper/35 p-4" aria-label={group.title}>
            <p class="font-mono text-xs font-black uppercase tracking-[0.22em] text-butter">{group.title}</p>
            <div class="mt-4 grid gap-2 text-sm text-paper/75">
              {group.links.map((link) => <a href={link.href} class="no-underline hover:text-butter">{link.label}</a>)}
            </div>
          </nav>
        ))}
      </div>
    </div>

    <div class="mt-8 flex flex-wrap items-center justify-between gap-4 border-t border-paper/35 pt-5">
      <div class="flex flex-wrap gap-x-4 gap-y-2 text-xs text-paper/65">
        {metaLinks.map((link) => <a href={link.href} class="no-underline hover:text-butter">{link.label}</a>)}
      </div>
      <p class="text-xs leading-5 text-paper/55">Data bisa berubah. Cek ulang info penting sebelum datang.</p>
    </div>
  </div>
</footer>
