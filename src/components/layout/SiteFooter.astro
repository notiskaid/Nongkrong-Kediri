---
import { SITE, QUICK_KEYWORDS } from '@/lib/constants';
---
<footer class="mt-16 border-t border-line bg-paper py-10">
  <div class="mx-auto grid max-w-6xl gap-8 px-4 sm:px-6 md:grid-cols-[1.5fr_1fr] lg:px-8">
    <div>
      <p class="text-lg font-semibold">{SITE.name}</p>
      <p class="mt-3 max-w-xl text-sm leading-7 text-muted">{SITE.description}</p>
      <p class="mt-5 text-xs text-muted">Dibuat sebagai direktori lokal yang kuratif, cepat, dan SEO-ready.</p>
    </div>
    <div>
      <p class="text-sm font-semibold">Shortcut</p>
      <div class="mt-3 flex flex-wrap gap-2">
        {QUICK_KEYWORDS.map((item) => (
          <a href={item.href} class="rounded-lg border border-line bg-surface px-3 py-1.5 text-xs text-muted no-underline hover:border-ink hover:text-ink">{item.label}</a>
        ))}
      </div>
    </div>
  </div>
</footer>
