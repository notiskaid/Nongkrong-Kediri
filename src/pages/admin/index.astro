---
import AdminLayout from '@/components/admin/AdminLayout.astro';
import StatusBadge from '@/components/admin/StatusBadge.astro';
import type { Place } from '@/types/place';
import type { SeoPage } from '@/types/seo-page';
import { getAllPlacesForAdmin } from '@/lib/queries/places';
import { getAllSeoPagesForAdmin } from '@/lib/queries/seo-pages';

let places: Place[] = [];
let seoPages: SeoPage[] = [];
let errorMessage = '';
try {
  [places, seoPages] = await Promise.all([
    getAllPlacesForAdmin(Astro.locals.supabase),
    getAllSeoPagesForAdmin(Astro.locals.supabase)
  ]);
} catch (error) {
  errorMessage = error instanceof Error ? error.message : 'Gagal mengambil data dashboard.';
}
const publishedPlaces = places.filter((p) => p.status === 'published').length;
const draftPlaces = places.filter((p) => p.status !== 'published').length;
const staleCutoff = Date.now() - 90 * 24 * 60 * 60 * 1000;
const needsReview = places
  .map((place) => {
    const missing: string[] = [];
    if (!place.featured_image_url) missing.push('foto');
    if (place.featured_image_url && !place.featured_image_alt) missing.push('alt');
    if (!place.address) missing.push('alamat');
    if (!place.google_maps_url) missing.push('maps');
    if (!place.categories?.length) missing.push('kategori');
    if (!place.use_cases?.length) missing.push('use case');
    if (!place.facilities?.length) missing.push('fasilitas');
    if (!place.excerpt || place.excerpt.trim().length < 80) missing.push('excerpt');
    if (!place.description || place.description.trim().length < 220) missing.push('deskripsi');
    const reviewedAt = place.last_reviewed_at ? new Date(place.last_reviewed_at).getTime() : 0;
    const stale = !reviewedAt || reviewedAt < staleCutoff;
    if (stale) missing.push('perlu cek ulang');
    return { place, missing, stale };
  })
  .filter((item) => item.missing.length > 0)
  .sort((a, b) => Number(b.stale) - Number(a.stale) || b.missing.length - a.missing.length);

function formatDate(value?: string | null) {
  if (!value) return 'belum dicek';
  return new Intl.DateTimeFormat('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }).format(new Date(value));
}
---
<AdminLayout title="Admin Dashboard">
  <div class="mb-8 flex flex-wrap items-start justify-between gap-4">
    <div>
      <h1 class="text-3xl font-bold">Dashboard</h1>
      <p class="mt-2 text-sm text-muted">Custom admin ringan untuk editorial directory.</p>
    </div>
    <a href="/admin/places/new/" class="rounded-xl border border-ink bg-ink px-4 py-2 text-sm font-semibold text-paper no-underline">Tambah tempat</a>
  </div>
  {!Astro.locals.isSupabaseConfigured && (
    <div class="mb-6 rounded-2xl border border-line bg-surface p-4 text-sm leading-6 text-muted">
      Database belum tersambung. Beberapa data mungkin belum bisa disimpan sampai konfigurasi selesai.
    </div>
  )}
  {errorMessage && <div class="mb-6 rounded-2xl border border-line bg-surface p-5 text-sm text-muted">{errorMessage}</div>}
  <div class="grid gap-4 sm:grid-cols-4">
    <div class="rounded-2xl border border-line bg-surface p-5"><p class="text-sm text-muted">Published places</p><p class="mt-2 text-3xl font-bold">{publishedPlaces}</p></div>
    <div class="rounded-2xl border border-line bg-surface p-5"><p class="text-sm text-muted">Draft/review</p><p class="mt-2 text-3xl font-bold">{draftPlaces}</p></div>
    <div class="rounded-2xl border border-line bg-surface p-5"><p class="text-sm text-muted">SEO pages</p><p class="mt-2 text-3xl font-bold">{seoPages.length}</p></div>
    <div class="rounded-2xl border border-line bg-butter/30 p-5"><p class="text-sm text-muted">Perlu dicek</p><p class="mt-2 text-3xl font-bold">{needsReview.length}</p></div>
  </div>
  <section class="mt-8 rounded-2xl border border-line bg-surface p-5">
    <div class="flex flex-wrap items-end justify-between gap-3">
      <div>
        <h2 class="text-xl font-semibold">Konten perlu dicek ulang</h2>
        <p class="mt-1 text-sm text-muted">Prioritas maintenance: data lama, incomplete, atau belum siap publish.</p>
      </div>
      <span class="rounded-full border border-ink px-3 py-1 font-mono text-xs uppercase tracking-[0.14em]">90 hari</span>
    </div>
    <div class="mt-4 overflow-x-auto">
      <table class="w-full text-left text-sm">
        <thead class="text-xs text-muted"><tr><th class="py-2">Nama</th><th>Terakhir dicek</th><th>Issue</th><th></th></tr></thead>
        <tbody>
          {needsReview.slice(0, 10).map(({ place, missing }) => (
            <tr class="border-t border-line"><td class="py-3 font-semibold">{place.name}</td><td class="text-muted">{formatDate(place.last_reviewed_at)}</td><td class="text-muted">{missing.slice(0, 5).join(', ')}</td><td><a href={`/admin/places/${place.id}/edit/`} class="no-underline">edit</a></td></tr>
          ))}
          {needsReview.length === 0 && <tr class="border-t border-line"><td colspan="4" class="py-4 text-muted">Semua tempat lolos checklist dasar.</td></tr>}
        </tbody>
      </table>
    </div>
  </section>
  <section class="mt-8 rounded-2xl border border-line bg-surface p-5">
    <h2 class="text-xl font-semibold">Tempat terbaru</h2>
    <div class="mt-4 overflow-x-auto">
      <table class="w-full text-left text-sm">
        <thead class="text-xs text-muted"><tr><th class="py-2">Nama</th><th>Status</th><th>Area</th><th></th></tr></thead>
        <tbody>
          {places.slice(0, 8).map((place) => (
            <tr class="border-t border-line"><td class="py-3 font-semibold">{place.name}</td><td><StatusBadge status={place.status} /></td><td class="text-muted">{place.area_name}</td><td><a href={`/admin/places/${place.id}/edit/`} class="no-underline">edit</a></td></tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</AdminLayout>
