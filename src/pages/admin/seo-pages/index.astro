---
import AdminLayout from '@/components/admin/AdminLayout.astro';
import StatusBadge from '@/components/admin/StatusBadge.astro';
import { getAllSeoPagesForAdmin } from '@/lib/queries/seo-pages';
const pages = await getAllSeoPagesForAdmin(Astro.locals.supabase);
---
<AdminLayout title="Admin SEO Pages">
  <div class="mb-6 flex flex-wrap items-center justify-between gap-4">
    <div><h1 class="text-3xl font-bold">SEO Pages</h1><p class="mt-2 text-sm text-muted">Landing page keyword berbasis query_config.</p></div>
    <a href="/admin/seo-pages/new/" class="rounded-xl border border-ink bg-ink px-4 py-2 text-sm font-semibold text-paper no-underline">Tambah SEO page</a>
  </div>
  <div class="overflow-hidden rounded-2xl border border-line bg-surface">
    <table class="w-full text-left text-sm">
      <thead class="border-b border-line text-xs text-muted"><tr><th class="p-3">H1</th><th class="p-3">Slug</th><th class="p-3">Status</th><th class="p-3"></th></tr></thead>
      <tbody>
        {pages.map((page) => (
          <tr class="border-b border-line last:border-0">
            <td class="p-3 font-semibold"><a href={`/${page.slug}/`} class="no-underline">{page.h1}</a></td>
            <td class="p-3 text-muted">/{page.slug}/</td>
            <td class="p-3"><StatusBadge status={page.status} /></td>
            <td class="p-3"><a href={`/admin/seo-pages/${page.id}/edit/`} class="no-underline">edit</a></td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</AdminLayout>
