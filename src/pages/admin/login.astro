---
import AdminLayout from '@/components/admin/AdminLayout.astro';
---
<AdminLayout title="Login Admin" showNav={false}>
  <div class="mx-auto max-w-md rounded-2xl border border-line bg-surface p-6">
    <h1 class="text-3xl font-bold">Login admin</h1>
    <p class="mt-3 text-sm leading-6 text-muted">Masuk menggunakan Supabase Auth. Email admin dikontrol lewat env ADMIN_EMAILS dan tabel admin_users.</p>
    <form id="login-form" class="mt-6 space-y-4">
      <label class="block text-sm">Email<input name="email" type="email" required class="mt-2 w-full rounded-xl border border-line bg-paper px-3 py-2" /></label>
      <label class="block text-sm">Password<input name="password" type="password" required class="mt-2 w-full rounded-xl border border-line bg-paper px-3 py-2" /></label>
      <button class="rounded-xl border border-ink bg-ink px-5 py-2 text-sm font-semibold text-paper">Login</button>
      <p id="login-message" class="text-sm text-muted"></p>
    </form>
  </div>
  <script>
    const form = document.querySelector<HTMLFormElement>('#login-form');
    const msg = document.querySelector<HTMLParagraphElement>('#login-message');
    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const formData = new FormData(form);
      const response = await fetch('/api/admin/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(Object.fromEntries(formData.entries()))
      });
      if (response.ok) {
        window.location.href = '/admin/';
      } else {
        const data = await response.json().catch(() => ({})) as { error?: string };
        if (msg) msg.textContent = data.error || 'Gagal login.';
      }
    });
  </script>
</AdminLayout>
