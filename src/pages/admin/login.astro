---
import AdminLayout from '@/components/admin/AdminLayout.astro';

let error = Astro.url.searchParams.get('error') || '';
---
<AdminLayout title="Login Admin" showNav={false}>
  <div class="mx-auto max-w-md rounded-2xl border border-line bg-surface p-6">
    <h1 class="text-3xl font-bold">Login Orang Ganteng</h1>
    <p class="mt-3 text-sm leading-6 text-muted">Kehidupan akan fana jika tanpa ngopi! Serta ngopi akan membuat hidup lebih bermakna.</p>
    <form id="login-form" method="post" action="/api/admin/login" class="mt-6 space-y-4">
      <label class="block text-sm">Email<input name="email" type="email" required class="mt-2 w-full rounded-xl border border-line bg-paper px-3 py-2" /></label>
      <label class="block text-sm">Password<input name="password" type="password" required class="mt-2 w-full rounded-xl border border-line bg-paper px-3 py-2" /></label>
      <button id="login-button" type="submit" class="rounded-xl border border-ink bg-ink px-5 py-2 text-sm font-semibold text-paper disabled:cursor-not-allowed disabled:opacity-60">Login</button>
      <p id="login-message" class="text-sm text-muted">{error}</p>
    </form>
  </div>
  <script is:inline>
    const form = document.querySelector('#login-form');
    const msg = document.querySelector('#login-message');
    const button = document.querySelector('#login-button');
    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (button) {
        button.disabled = true;
        button.textContent = 'Login...';
      }
      if (msg) msg.textContent = '';
      const formData = new FormData(form);
      try {
        const response = await fetch('/api/admin/login', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(Object.fromEntries(formData.entries()))
        });
        const data = await response.json().catch(() => ({}));
        if (response.ok) {
          window.location.assign('/admin/');
          return;
        }
        if (msg) msg.textContent = data.error || 'Gagal login.';
      } catch {
        if (msg) msg.textContent = 'Koneksi gagal. Coba lagi.';
      } finally {
        if (button) {
          button.disabled = false;
          button.textContent = 'Login';
        }
      }
    });
  </script>
</AdminLayout>
