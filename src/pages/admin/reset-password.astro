---
import AdminLayout from '@/components/admin/AdminLayout.astro';
---
<AdminLayout title="Reset Password Admin" showNav={false}>
  <div class="mx-auto max-w-md rounded-2xl border border-line bg-surface p-6">
    <h1 class="text-3xl font-bold">Reset password</h1>
    <p class="mt-3 text-sm leading-6 text-muted">Masukkan password baru untuk akun admin.</p>
    <form id="reset-form" class="mt-6 space-y-4">
      <label class="block text-sm">Password baru<input name="password" type="password" minlength="6" required class="mt-2 w-full rounded-xl border border-line bg-paper px-3 py-2" /></label>
      <label class="block text-sm">Ulangi password<input name="confirm" type="password" minlength="6" required class="mt-2 w-full rounded-xl border border-line bg-paper px-3 py-2" /></label>
      <button id="reset-button" type="submit" class="rounded-xl border border-ink bg-ink px-5 py-2 text-sm font-semibold text-paper disabled:cursor-not-allowed disabled:opacity-60">Simpan password</button>
      <p id="reset-message" class="text-sm text-muted"></p>
    </form>
    <p class="mt-4 text-xs text-muted"><a href="/admin/login/" class="underline underline-offset-4">Kembali ke login</a></p>
  </div>
  <script>
    import { createClient } from '@supabase/supabase-js';

    const supabase = createClient(import.meta.env.PUBLIC_SUPABASE_URL, import.meta.env.PUBLIC_SUPABASE_ANON_KEY);
    const form = document.querySelector<HTMLFormElement>('#reset-form');
    const msg = document.querySelector<HTMLParagraphElement>('#reset-message');
    const button = document.querySelector<HTMLButtonElement>('#reset-button');

    const hashParams = new URLSearchParams(window.location.hash.slice(1));
    const searchParams = new URLSearchParams(window.location.search);
    const accessToken = hashParams.get('access_token');
    const refreshToken = hashParams.get('refresh_token');
    const errorDescription = hashParams.get('error_description') || searchParams.get('error_description');

    if (errorDescription && msg) msg.textContent = decodeURIComponent(errorDescription.replace(/\+/g, ' '));

    if (accessToken && refreshToken) {
      await supabase.auth.setSession({ access_token: accessToken, refresh_token: refreshToken });
      history.replaceState(null, '', '/admin/reset-password/');
    }

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const formData = new FormData(form);
      const password = String(formData.get('password') || '');
      const confirm = String(formData.get('confirm') || '');
      if (password !== confirm) {
        if (msg) msg.textContent = 'Password tidak sama.';
        return;
      }
      if (button) {
        button.disabled = true;
        button.textContent = 'Menyimpan...';
      }
      const { error } = await supabase.auth.updateUser({ password });
      if (error) {
        if (msg) msg.textContent = error.message;
        if (button) {
          button.disabled = false;
          button.textContent = 'Simpan password';
        }
        return;
      }
      if (msg) msg.textContent = 'Password berhasil diubah. Mengarahkan ke login...';
      await supabase.auth.signOut();
      window.location.assign('/admin/login/');
    });
  </script>
</AdminLayout>
