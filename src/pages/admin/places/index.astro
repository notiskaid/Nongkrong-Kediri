---
import AdminLayout from '@/components/admin/AdminLayout.astro';
import StatusBadge from '@/components/admin/StatusBadge.astro';
import type { Place } from '@/types/place';
import { getAllPlacesForAdmin } from '@/lib/queries/places';
let places: Place[] = [];
let errorMessage = '';
try {
  places = await getAllPlacesForAdmin(Astro.locals.supabase);
} catch (error) {
  errorMessage = error instanceof Error ? error.message : 'Gagal mengambil data tempat.';
}
---
<AdminLayout title="Admin Places">
  <div class="mb-6 flex flex-wrap items-center justify-between gap-4">
    <div><h1 class="text-3xl font-bold">Places</h1><p class="mt-2 text-sm text-muted">Satu tempat diinput sekali, lalu masuk banyak landing page.</p></div>
    <a href="/admin/places/new/" class="rounded-xl border border-ink bg-ink px-4 py-2 text-sm font-semibold text-paper no-underline">Tambah tempat</a>
  </div>
  {errorMessage && <div class="mb-5 rounded-2xl border border-line bg-surface p-5 text-sm text-muted">{errorMessage}</div>}
  {!errorMessage && <div class="overflow-hidden rounded-2xl border border-line bg-surface">
    <table class="w-full text-left text-sm">
      <thead class="border-b border-line text-xs text-muted"><tr><th class="p-3">Nama</th><th class="p-3">Status</th><th class="p-3">Area</th><th class="p-3">Kategori</th><th class="p-3"></th></tr></thead>
      <tbody>
        {places.map((place) => (
          <tr class="border-b border-line last:border-0"><td class="p-3 font-semibold"><a href={`/tempat/${place.slug}/`} class="no-underline">{place.name}</a></td><td class="p-3"><StatusBadge status={place.status} /></td><td class="p-3 text-muted">{place.area_name}</td><td class="p-3 text-muted">{place.categories.map((c) => c.name).join(', ')}</td><td class="p-3"><a href={`/admin/places/${place.id}/edit/`} class="no-underline">edit</a></td></tr>
        ))}
      </tbody>
    </table>
  </div>}
</AdminLayout>
