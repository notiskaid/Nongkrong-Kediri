---
import PlaceLayout from '@/layouts/PlaceLayout.astro';
import Container from '@/components/base/Container.astro';
import Breadcrumbs from '@/components/layout/Breadcrumbs.astro';
import PlaceHero from '@/components/place/PlaceHero.astro';
import PlaceQuickFacts from '@/components/place/PlaceQuickFacts.astro';
import PlaceFacilities from '@/components/place/PlaceFacilities.astro';
import PlaceUseCases from '@/components/place/PlaceUseCases.astro';
import PlaceOpeningHours from '@/components/place/PlaceOpeningHours.astro';
import PlaceMapCTA from '@/components/place/PlaceMapCTA.astro';
import PlaceGallery from '@/components/place/PlaceGallery.astro';
import PlaceReportForm from '@/components/place/PlaceReportForm';
import PlaceReviewSection from '@/components/place/PlaceReviewSection';
import RelatedPlaces from '@/components/place/RelatedPlaces.astro';
import { getPlaceBySlug, getRelatedPlaces } from '@/lib/queries/places';
import { breadcrumbSchema, placeSchema } from '@/lib/seo/schema';

const slug = Astro.params.slug!;
const place = await getPlaceBySlug(Astro.locals.supabase, slug);

if (!place) {
  Astro.response.status = 404;
}
const relatedPlaces = place ? await getRelatedPlaces(Astro.locals.supabase, place) : [];
const breadcrumbs = place ? breadcrumbSchema([{ name: 'Home', href: '/' }, { name: 'Tempat', href: '/tempat-ngopi-kediri/' }, { name: place.name, href: `/tempat/${place.slug}/` }]) : null;
const internalLinks = place ? [
  place.area_slug && { label: `Tempat di ${place.area_name}`, href: `/area/${place.area_slug}/` },
  place.categories?.[0] && { label: `${place.categories[0].name} Kediri`, href: `/${place.categories[0].slug}-kediri/` },
  place.use_cases?.[0] && { label: `${place.use_cases[0].name} Kediri`, href: `/${place.use_cases[0].slug}-kediri/` }
].filter(Boolean) as { label: string; href: string }[] : [];
---
<PlaceLayout
  title={place?.meta_title || (place ? `${place.name}: Alamat, Jam Buka, Fasilitas & Review` : 'Tempat tidak ditemukan')}
  description={place?.meta_description || place?.excerpt || 'Tempat tidak ditemukan.'}
  robots={place?.robots || 'index,follow'}
  image={place?.featured_image_url}
  jsonLd={place ? [placeSchema(place), breadcrumbs] : []}
>
  <Container class="py-10">
    {place ? (
      <>
        <Breadcrumbs items={[{ label: 'tempat ngopi', href: '/tempat-ngopi-kediri/' }, { label: place.name }]} />
        <PlaceHero place={place} />
        <div class="mt-10 space-y-8">
          <PlaceQuickFacts place={place} />
          <section class="grid gap-8 lg:grid-cols-[1fr_360px]">
            <article class="space-y-8">
              <div class="prose-nk rounded-[1.75rem] border border-line bg-surface p-6">
                <h2>Tentang {place.name}</h2>
                <p>{place.description || place.excerpt || 'Deskripsi editorial belum tersedia.'}</p>
                {place.editorial_notes && <p>{place.editorial_notes}</p>}
                <h2>Yang perlu diketahui sebelum datang</h2>
                <ul>
                  <li>Area: {place.area_name || 'Kediri'}.</li>
                  <li>Kisaran harga: {place.price_label || 'belum dicatat'}.</li>
                  <li>Cocok untuk: {place.use_cases?.map((term) => term.name).join(', ') || 'nongkrong santai'}.</li>
                  <li>Fasilitas tercatat: {place.facilities?.map((term) => term.name).join(', ') || 'belum dicatat'}.</li>
                </ul>
                {internalLinks.length > 0 && (
                  <>
                    <h2>Jelajahi rekomendasi terkait</h2>
                    <p>Kalau masih membandingkan pilihan, lanjutkan dari halaman terkait ini:</p>
                    <ul>{internalLinks.map((link) => <li><a href={link.href}>{link.label}</a></li>)}</ul>
                  </>
                )}
              </div>
              <PlaceGallery place={place} />
              <PlaceReportForm client:load placeId={place.id} placeName={place.name} />
              <PlaceReviewSection client:load />
            </article>
            <aside class="space-y-5 lg:sticky lg:top-24 lg:self-start">
              <PlaceFacilities place={place} />
              <PlaceUseCases place={place} />
              <PlaceOpeningHours place={place} />
              <PlaceMapCTA place={place} />
            </aside>
          </section>
          <RelatedPlaces places={relatedPlaces} />
        </div>
      </>
    ) : (
      <div class="rounded-2xl border border-line bg-surface p-8">
        <h1 class="text-3xl font-bold">Tempat tidak ditemukan</h1>
        <p class="mt-3 text-muted">Data tempat ini belum ada atau belum dipublish.</p>
      </div>
    )}
  </Container>
</PlaceLayout>
