---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/base/Container.astro';
Astro.response.status = 404;
---
<BaseLayout title="Artikel belum tersedia" robots="noindex,follow">
  <Container class="py-10">
    <div class="rounded-2xl border border-line bg-surface p-8">
      <h1 class="text-3xl font-bold">Artikel belum tersedia</h1>
      <p class="mt-3 text-muted">Folder blog sudah disiapkan untuk fase konten editorial berikutnya.</p>
    </div>
  </Container>
</BaseLayout>
