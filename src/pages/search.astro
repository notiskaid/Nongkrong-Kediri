---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Container from '@/components/base/Container.astro';
import SearchBox from '@/components/listing/SearchBox';
import PlaceListingGrid from '@/components/listing/PlaceListingGrid.astro';
import { searchPlaces } from '@/lib/queries/places';

const q = Astro.url.searchParams.get('q') || '';
const places = await searchPlaces(Astro.locals.supabase, q);
---
<BaseLayout title="Cari Tempat" description="Cari tempat ngopi, cafe, WFC, dan tempat nongkrong di Kediri." robots="noindex,follow">
  <Container class="py-10">
    <header class="section-masthead border-y border-ink p-6">
      <p class="editorial-label mb-3">Search desk</p>
      <h1 class="display-heading text-6xl sm:text-8xl">Cari tempat</h1>
      <p class="mt-4 text-muted">Cari berdasarkan nama tempat, area, suasana, atau kebutuhan seperti WFC dan outdoor.</p>
    </header>
    <div class="mt-8 max-w-2xl border border-ink bg-surface p-3 shadow-offset">
      <SearchBox client:load defaultValue={q} />
    </div>
    <section class="mt-8">
      <p class="mb-4 font-mono text-xs uppercase tracking-[0.18em] text-muted">{places.length} hasil {q ? `untuk “${q}”` : 'tersedia'}.</p>
      <PlaceListingGrid places={places} emptyTitle="Tidak ada hasil" emptyDescription="Coba kata kunci lain seperti WFC, outdoor, murah, atau nama area." />
    </section>
  </Container>
</BaseLayout>
