---
import 'remixicon/fonts/remixicon.css';
import '@/assets/styles/global.css';
import SiteHeader from '@/components/layout/SiteHeader.astro';
import SiteFooter from '@/components/layout/SiteFooter.astro';
import CustomScripts from '@/components/seo/CustomScripts.astro';
import { titleTemplate, truncateDescription } from '@/lib/seo/meta';
import { canonicalUrl } from '@/lib/seo/canonical';
import { siteUrl } from '@/lib/constants';

const {
  title,
  description,
  canonical,
  robots = 'index,follow',
  image,
  jsonLd = [],
  hideHeader = false,
  hideFooter = false
} = Astro.props;

const pageTitle = titleTemplate(title);
const pageDescription = truncateDescription(description);
const runtimeSiteUrl = Astro.locals.runtime?.env?.PUBLIC_SITE_URL;
const pageCanonical = canonical || canonicalUrl(Astro.url.pathname, null, runtimeSiteUrl);
const ogParams = new URLSearchParams({ title: String(title || 'Nongkrong Kediri'), description: pageDescription });
const pageImage = image || `${runtimeSiteUrl || siteUrl()}/api/og?${ogParams.toString()}`;
const schemas = Array.isArray(jsonLd) ? jsonLd.filter(Boolean) : [jsonLd].filter(Boolean);
---
<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={pageCanonical} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={pageCanonical} />
    <meta property="og:image" content={pageImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={pageImage} />
    <meta name="theme-color" content="#111111" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <CustomScripts placement="head" />
    <slot name="head" />
    <script is:inline>
      try {
        const saved = localStorage.getItem('nk-theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if ((saved && saved === 'dark') || (!saved && prefersDark)) document.documentElement.classList.add('dark');
      } catch {}
    </script>
    {schemas.map((schema) => <script type="application/ld+json" set:html={JSON.stringify(schema)} />)}
  </head>
  <body>
    <CustomScripts placement="body-start" />
    <slot name="body-start" />
    {!hideHeader && <SiteHeader />}
    <main>
      <slot />
    </main>
    {!hideFooter && <SiteFooter />}
    <slot name="body-end" />
  </body>
</html>
